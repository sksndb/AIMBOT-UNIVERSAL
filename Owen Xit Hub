-- ==================== FUNCIONES ESP ====================
local function CreateESP(p)
    if ESPObjects[p] then return end
    local char = p.Character
    if not char then return end

    local data = { Links = char:FindFirstChild("UpperTorso") and R15Links or R6Links }

    data.Box              = Drawing.new("Square")
    data.Box.Filled       = false
    data.Box.Transparency = 1
    data.Box.Thickness    = ESPSettings.Thickness
    data.Box.Color        = ESPSettings.Color
    data.Box.Visible      = false

    data.Tracer              = Drawing.new("Line")
    data.Tracer.Thickness    = 1.5
    data.Tracer.Transparency = 1
    data.Tracer.Color        = ESPSettings.Color
    data.Tracer.Visible      = false

    data.Name              = Drawing.new("Text")
    data.Name.Center       = true
    data.Name.Outline      = true
    data.Name.OutlineColor = Color3.new(0, 0, 0)
    data.Name.Font         = 2
    data.Name.Size         = ESPSettings.TextSize
    data.Name.Transparency = 1
    data.Name.Color        = ESPSettings.Color
    data.Name.Visible      = false

    data.HBBG              = Drawing.new("Square")
    data.HBBG.Filled       = true
    data.HBBG.Color        = Color3.new(0, 0, 0)
    data.HBBG.Transparency = 0.5
    data.HBBG.Visible      = false

    data.HB              = Drawing.new("Square")
    data.HB.Filled       = true
    data.HB.Transparency = 1
    data.HB.Visible      = false

    data.SkelLines = {}
    for _ = 1, #data.Links do
        local ln           = Drawing.new("Line")
        ln.Thickness       = 1.5
        ln.Transparency    = 0.8
        ln.Color           = ESPSettings.Color
        ln.Visible         = false
        table.insert(data.SkelLines, ln)
    end

    data.Highlight                     = Instance.new("Highlight")
    data.Highlight.FillTransparency    = ESPSettings.HighlightTransparency
    data.Highlight.OutlineTransparency = 0
    data.Highlight.FillColor           = ESPSettings.Color
    data.Highlight.OutlineColor        = ESPSettings.Color
    data.Highlight.Adornee             = char
    data.Highlight.Parent              = Camera
    data.Highlight.Enabled             = false

    ESPObjects[p] = data
end

local function RemoveESP(p)
    local d = ESPObjects[p]
    if not d then return end
    if d.Box     then d.Box:Remove()     end
    if d.Tracer  then d.Tracer:Remove()  end
    if d.Name    then d.Name:Remove()    end
    if d.HBBG    then d.HBBG:Remove()    end
    if d.HB      then d.HB:Remove()      end
    for _, l in ipairs(d.SkelLines or {}) do l:Remove() end
    if d.Highlight then d.Highlight:Destroy() end
    ESPObjects[p] = nil
end

local function RefreshAllESP()
    for _, p in Players:GetPlayers() do
        if p ~= LP then
            RemoveESP(p)
            if ESPSettings.Enabled then CreateESP(p) end
        end
    end
end

-- ==================== AIMBOT LOGIC ====================
local function GetClosestPlayer()
    local s = Env.Settings
    RequiredDistance = Env.FOVSettings.Enabled and (330 - Env.FOVSettings.Radius) or 2000

    local Closest, closest_dist = nil, RequiredDistance

    for _, p in Players:GetPlayers() do
        if p == LP then continue end
        local c = p.Character
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if not (c and h and h.Health > 0 and c:FindFirstChild(s.LockPart)) then continue end
        if s.TeamCheck and p.Team == LP.Team then continue end
        if table.find(Env.Blacklisted, p.Name) then continue end

        local part = c[s.LockPart]

        if s.WallCheck then
            local ignore = {}
            if LP.Character then
                for _, v in LP.Character:GetDescendants() do table.insert(ignore, v) end
            end
            for _, v in c:GetDescendants() do table.insert(ignore, v) end
            if #Camera:GetPartsObscuringTarget({part.Position}, ignore) > 0 then continue end
        end

        if s.VisibleCheck then
            local v2, onScr = Camera:WorldToViewportPoint(part.Position)
            if not onScr or v2.Z < 0 then continue end
        end

        local vec, onScr = Camera:WorldToViewportPoint(part.Position)
        local d = (UIS:GetMouseLocation() - Vector2.new(vec.X, vec.Y)).Magnitude
        if d < closest_dist and onScr then
            closest_dist = d
            Closest = p
        end
    end
    return Closest
end

-- ==================== RUNSERVICE STEPPED ====================
RunService.Stepped:Connect(function()
    FrameCounter += 1
    if FrameCounter % 2 ~= 0 then return end

    local f  = Env.FOVSettings
    local s  = Env.Settings
    local fc = Env.FOVCircle
    local fo = Env.FOVCircleOutline

    -- FOV
    if f.Enabled and s.Enabled and not StreamingMode then
        local col = Env.Locked and f.LockedColor or
            (f.RainbowColor and Color3.fromHSV(tick() % 5, 1, 1) or f.Color)
        fc.Radius       = f.Radius
        fc.NumSides     = f.NumSides
        fc.Thickness    = f.Thickness
        fc.Transparency = f.Transparency
        fc.Filled       = f.Filled
        fc.Visible      = f.Visible
        fc.Position     = UIS:GetMouseLocation()
        fc.Color        = col
        fo.Radius       = f.Radius + f.Thickness
        fo.NumSides     = f.NumSides
        fo.Thickness    = f.Thickness + 1
        fo.Transparency = f.Transparency
        fo.Visible      = f.Visible
        fo.Position     = UIS:GetMouseLocation()
        fo.Color        = f.RainbowOutlineColor and Color3.fromHSV(tick() % 5, 1, 1) or f.OutlineColor
    else
        fc.Visible = false
        fo.Visible = false
    end

    if not ESPSettings.Enabled then return end

    for _, p in Players:GetPlayers() do
        if p == LP then continue end

        local c    = p.Character
        local root = c and c:FindFirstChild("HumanoidRootPart")
        local hum  = c and c:FindFirstChild("Humanoid")
        local head = c and c:FindFirstChild("Head")

        if not (root and hum and head and hum.Health > 0) then
            RemoveESP(p)
            continue
        end

        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local dist   = myRoot and (myRoot.Position - root.Position).Magnitude or 9999

        if dist > ESPSettings.MaxDistance then RemoveESP(p) continue end
        if ESPSettings.TeamCheck and p.Team == LP.Team then RemoveESP(p) continue end
        if not ESPObjects[p] then CreateESP(p) end

        local d = ESPObjects[p]
        if not d then continue end

        local rPos, onScr = Camera:WorldToViewportPoint(root.Position)

        if not onScr or StreamingMode then
            d.Box.Visible       = false
            d.Tracer.Visible    = false
            d.Name.Visible      = false
            d.HBBG.Visible      = false
            d.HB.Visible        = false
            for _, l in d.SkelLines do l.Visible = false end
            d.Highlight.Enabled = false
            continue
        end

        local isLocked  = Env.Locked == p
        local baseColor = ESPSettings.Rainbow and Color3.fromHSV((tick()*0.5 + p.UserId/255)%1, 1, 1) or ESPSettings.Color
        local drawColor = isLocked and ESPSettings.LockedColor or baseColor

        -- Box
        if ESPSettings.Boxes then
            local topV = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.6, 0))
            local botV = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
            local bh   = math.abs(topV.Y - botV.Y)
            local bw   = bh * 0.45
            d.Box.Size      = Vector2.new(bw, bh)
            d.Box.Position  = Vector2.new(rPos.X - bw / 2, topV.Y)
            d.Box.Color     = drawColor
            d.Box.Thickness = ESPSettings.Thickness
            d.Box.Visible   = true
        else
            d.Box.Visible = false
        end

        -- Tracer
        if ESPSettings.Tracers then
            d.Tracer.From    = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            d.Tracer.To      = Vector2.new(rPos.X, rPos.Y + 20)
            d.Tracer.Color   = drawColor
            d.Tracer.Visible = true
        else
            d.Tracer.Visible = false
        end

        -- Names
        if ESPSettings.Names then
            local hPos      = Camera:WorldToViewportPoint(head.Position)
            d.Name.Text     = p.Name .. "\n" .. math.floor(hum.Health) .. " HP | " .. math.floor(dist) .. "u"
            d.Name.Position = Vector2.new(rPos.X, hPos.Y - 40)
            d.Name.Color    = drawColor
            d.Name.Size     = ESPSettings.TextSize
            d.Name.Visible  = true
        else
            d.Name.Visible = false
        end

        -- Health bars
        if ESPSettings.HealthBars then
            local topV = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.6, 0))
            local botV = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
            local barH = math.abs(topV.Y - botV.Y)
            local boxW = d.Box.Visible and d.Box.Size.X or 50
            local barX = rPos.X + boxW / 2 + 5

            d.HBBG.Position = Vector2.new(barX, topV.Y)
            d.HBBG.Size     = Vector2.new(4, barH)
            d.HBBG.Visible  = true

            local perc    = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            d.HB.Color    = Color3.fromRGB(255 * (1 - perc), 255 * perc, 0)
            d.HB.Position = Vector2.new(barX + 0.5, topV.Y + barH * (1 - perc))
            d.HB.Size     = Vector2.new(3, barH * perc)
            d.HB.Visible  = true
        else
            d.HBBG.Visible = false
            d.HB.Visible   = false
        end

        -- Skeleton
        if ESPSettings.Skeleton then
            for i, line in ipairs(d.SkelLines) do
                local pair = d.Links[i]
                local p1   = c:FindFirstChild(pair[1])
                local p2   = c:FindFirstChild(pair[2])
                if p1 and p2 then
                    local v1     = Camera:WorldToViewportPoint(p1.Position)
                    local v2     = Camera:WorldToViewportPoint(p2.Position)
                    line.From    = Vector2.new(v1.X, v1.Y)
                    line.To      = Vector2.new(v2.X, v2.Y)
                    line.Color   = drawColor
                    line.Visible = true
                else
                    line.Visible = false
                end
            end
        else
            for _, l in d.SkelLines do l.Visible = false end
        end

        -- Highlight
        d.Highlight.FillTransparency = ESPSettings.HighlightTransparency
        d.Highlight.FillColor        = drawColor
        d.Highlight.OutlineColor     = drawColor
        d.Highlight.Adornee          = c
        d.Highlight.Enabled          = true
    end
end)

-- ==================== AIMBOT HEARTBEAT ====================
RunService.Heartbeat:Connect(function()
    if not Running or not Env.Settings.Enabled or not Env.Locked then return end
    local char = Env.Locked.Character
    local part = char and char:FindFirstChild(Env.Settings.LockPart)
    if not part then
        if CurrentTween then CurrentTween:Cancel() CurrentTween = nil end
        Env.Locked = nil
        Running    = false
        return
    end

    local target = part.Position
    local scr    = Camera:WorldToViewportPoint(target)

    if Env.Settings.LockMode == 2 then
        mousemoverel(
            (scr.X - UIS:GetMouseLocation().X) / Env.Settings.Sensitivity2,
            (scr.Y - UIS:GetMouseLocation().Y) / Env.Settings.Sensitivity2
        )
    else
        if Env.Settings.Sensitivity > 0 then
            if CurrentTween then CurrentTween:Cancel() end
            CurrentTween = TweenService:Create(Camera,
                TweenInfo.new(Env.Settings.Sensitivity, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                { CFrame = CFrame.new(Camera.CFrame.Position, target) }
            )
            CurrentTween:Play()
        else
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target)
        end
    end
end)

-- ==================== TRIGGERBOT HEARTBEAT ====================
RunService.Heartbeat:Connect(function()
    if not getgenv().TriggerbotEnabled then return end
    if not (Env.Locked and Running) then return end

    local char = Env.Locked.Character
    local part = char and char:FindFirstChild(Env.Settings.LockPart)
    if not part then return end

    local myChar = LP.Character
    if not myChar then return end

    local ignore = {}
    for _, v in ipairs(myChar:GetDescendants()) do table.insert(ignore, v) end
    for _, v in ipairs(char:GetDescendants()) do table.insert(ignore, v) end
    if #Camera:GetPartsObscuringTarget({part.Position}, ignore) > 0 then return end

    local vec, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen or vec.Z < 0 then return end

    local now = tick()
    if now - LastShot >= TriggerbotDelay then
        VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
        task.wait(0.015)
        VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        LastShot = now
    end
end)

