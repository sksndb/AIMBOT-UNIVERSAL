    AimbotTab:CreateDropdown({
        Name = "Tecla de Activación",
        Options = {"Z", "T", "Q", "E", "X", "G", "H", "F", "R", "Clic Izquierdo", "Clic Derecho", "Clic Central"},
        CurrentOption = {"Z"},
        MultipleOptions = false,
        Flag = "Aimbot_TriggerKey",
        Callback = function(sel)
            local opt = type(sel) == "table" and sel[1] or sel
            local keyMap = {
                Z = Enum.KeyCode.Z, T = Enum.KeyCode.T, Q = Enum.KeyCode.Q,
                E = Enum.KeyCode.E, X = Enum.KeyCode.X, G = Enum.KeyCode.G,
                H = Enum.KeyCode.H, F = Enum.KeyCode.F, R = Enum.KeyCode.R,
            }
            if opt == "Clic Izquierdo" then
                G.CurrentTriggerKey  = nil
                G.CurrentTriggerType = Enum.UserInputType.MouseButton1
            elseif opt == "Clic Derecho" then
                G.CurrentTriggerKey  = nil
                G.CurrentTriggerType = Enum.UserInputType.MouseButton2
            elseif opt == "Clic Central" then
                G.CurrentTriggerKey  = nil
                G.CurrentTriggerType = Enum.UserInputType.MouseButton3
            else
                G.CurrentTriggerType = nil
                G.CurrentTriggerKey  = keyMap[opt] or Enum.KeyCode.Z
            end
            Rayfield:Notify({Title="Tecla", Content="Activación: "..opt, Duration=2})
        end
