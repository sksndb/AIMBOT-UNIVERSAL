local function GetClosestPlayer()
    local fovR = G.FOVEnabled and (330 - G.FOVRadius) or 2000
    local best, bestDist = nil, fovR
    for _, p in Players:GetPlayers() do
        if p == LP then continue end
        local c = p.Character
        local h = c and c:FindFirstChildOfClass("Humanoid")
        if not (c and h and h.Health > 0 and c:FindFirstChild(G.LockPart)) then continue end
        if G.TeamCheckAimbot and p.Team == LP.Team then continue end
        if table.find(G.Blacklisted, p.Name) then continue end
        local part = c[G.LockPart]
        if G.WallCheck then
            local ignore = {}
            if LP.Character then for _,v in LP.Character:GetDescendants() do table.insert(ignore,v) end end
            for _,v in c:GetDescendants() do table.insert(ignore,v) end
            if #Camera:GetPartsObscuringTarget({part.Position}, ignore) > 0 then continue end
        end
        local vec, onScr = Camera:WorldToViewportPoint(part.Position)
        if not onScr or vec.Z < 0 then continue end
        local d = (UIS:GetMouseLocation() - Vector2.new(vec.X, vec.Y)).Magnitude
        if d < bestDist then bestDist = d; best = p end
    end
    return best
end

-- RunService loops
local frameCounter = 0
RunService.Stepped:Connect(function()
    frameCounter = frameCounter + 1
    if frameCounter % 2 ~= 0 then return end

    -- FOV Circle
    if G.FOVEnabled and G.AimbotEnabled then
        local lockedCol = G.AimLocked and G.FOVLockedColor or G.FOVColor
        local col = G.FOVRainbow and Color3.fromHSV(tick()%5, 1, 1) or lockedCol
        local oc  = G.FOVRainbowOutline and Color3.fromHSV(tick()%5, 1, 1) or G.FOVOutlineColor

        G.FOVCircle.Radius       = G.FOVRadius
        G.FOVCircle.NumSides     = G.FOVNumSides
        G.FOVCircle.Thickness    = G.FOVThickness
        G.FOVCircle.Transparency = 1
        G.FOVCircle.Filled       = G.FOVFilled
        G.FOVCircle.Visible      = G.FOVVisible
        G.FOVCircle.Color        = col
        G.FOVCircle.Position     = UIS:GetMouseLocation()

        G.FOVCircleOutline.Radius       = G.FOVRadius + G.FOVThickness
        G.FOVCircleOutline.NumSides     = G.FOVNumSides
        G.FOVCircleOutline.Thickness    = G.FOVThickness + 1
        G.FOVCircleOutline.Transparency = 1
        G.FOVCircleOutline.Visible      = G.FOVVisible
        G.FOVCircleOutline.Color        = oc
        G.FOVCircleOutline.Position     = UIS:GetMouseLocation()
    else
        G.FOVCircle.Visible        = false
        G.FOVCircleOutline.Visible = false
    end

    -- ESP
    if not G.ESPEnabled then
        for _, p in Players:GetPlayers() do
            if p ~= LP then RemoveESP(p) end
        end
        return
    end

    for _, p in Players:GetPlayers() do
        if p == LP then continue end
        local c    = p.Character
        local root = c and c:FindFirstChild("HumanoidRootPart")
        local hum  = c and c:FindFirstChild("Humanoid")
        local head = c and c:FindFirstChild("Head")

        if not (root and hum and head and hum.Health > 0) then RemoveESP(p); continue end

        local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local dist   = myRoot and (myRoot.Position - root.Position).Magnitude or 9999

        if dist > G.ESPMaxDistance then RemoveESP(p); continue end
        if G.ESPTeamCheck and p.Team == LP.Team then RemoveESP(p); continue end
        if not G.ESPObjects[p] then CreateESP(p) end

        local d = G.ESPObjects[p]
        if not d then continue end

        local rPos, onScr = Camera:WorldToViewportPoint(root.Position)
        if not onScr then
            d.Box.Visible = false; d.Tracer.Visible = false; d.Name.Visible = false
            d.HBBG.Visible = false; d.HB.Visible = false
            for _, l in d.SkelLines do l.Visible = false end
            d.Highlight.Enabled = false
            continue
        end

        local isLocked  = G.AimLocked == p
        local baseColor = G.ESPRainbow and Color3.fromHSV((tick()*0.5+p.UserId/255)%1,1,1) or G.ESPColor
        local drawColor = isLocked and G.ESPLockedColor or baseColor

        if G.ESPBoxes then
            local topV = Camera:WorldToViewportPoint(head.Position+Vector3.new(0,0.6,0))
            local botV = Camera:WorldToViewportPoint(root.Position-Vector3.new(0,3.5,0))
            local bh   = math.abs(topV.Y - botV.Y)
            local bw   = bh * 0.45
            d.Box.Size = Vector2.new(bw, bh)
            d.Box.Position = Vector2.new(rPos.X - bw/2, topV.Y)
            d.Box.Color = drawColor; d.Box.Thickness = G.ESPThickness; d.Box.Visible = true
        else d.Box.Visible = false end

        if G.ESPTracers then
            d.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
            d.Tracer.To   = Vector2.new(rPos.X, rPos.Y+20)
            d.Tracer.Color = drawColor; d.Tracer.Visible = true
        else d.Tracer.Visible = false end

        if G.ESPNames then
            local hPos = Camera:WorldToViewportPoint(head.Position)
            d.Name.Text     = p.Name.."\n"..math.floor(hum.Health).." HP | "..math.floor(dist).."u"
            d.Name.Position = Vector2.new(rPos.X, hPos.Y - 40)
            d.Name.Color = drawColor; d.Name.Size = G.ESPTextSize; d.Name.Visible = true
        else d.Name.Visible = false end

        if G.ESPHealthBars then
            local topV = Camera:WorldToViewportPoint(head.Position+Vector3.new(0,0.6,0))
            local botV = Camera:WorldToViewportPoint(root.Position-Vector3.new(0,3.5,0))
            local barH = math.abs(topV.Y - botV.Y)
            local boxW = d.Box.Visible and d.Box.Size.X or 50
            local barX = rPos.X + boxW/2 + 5
            d.HBBG.Position = Vector2.new(barX, topV.Y); d.HBBG.Size = Vector2.new(4, barH); d.HBBG.Visible = true
            local perc = math.clamp(hum.Health/hum.MaxHealth, 0, 1)
            d.HB.Color    = Color3.fromRGB(255*(1-perc), 255*perc, 0)
            d.HB.Position = Vector2.new(barX+0.5, topV.Y + barH*(1-perc))
            d.HB.Size     = Vector2.new(3, barH*perc); d.HB.Visible = true
        else d.HBBG.Visible = false; d.HB.Visible = false end

        if G.ESPSkeleton then
            for i, ln in ipairs(d.SkelLines) do
                local pair = d.Links[i]
                local p1 = c:FindFirstChild(pair[1])
                local p2 = c:FindFirstChild(pair[2])
                if p1 and p2 then
                    local v1 = Camera:WorldToViewportPoint(p1.Position)
                    local v2 = Camera:WorldToViewportPoint(p2.Position)
                    ln.From = Vector2.new(v1.X,v1.Y); ln.To = Vector2.new(v2.X,v2.Y)
                    ln.Color = drawColor; ln.Visible = true
                else ln.Visible = false end
            end
        else
            for _, l in d.SkelLines do l.Visible = false end
        end

        d.Highlight.FillTransparency = G.ESPHighlightTrans
        d.Highlight.FillColor        = drawColor
        d.Highlight.OutlineColor     = drawColor
        d.Highlight.Adornee          = c
        d.Highlight.Enabled          = true
    end
end)

