local function getIngredientCounts()
    local w, s, g = 0, 0, 0
    local function check(name)
        name = name:lower()
        if name:find("agua") or name:find("water") then w = w + 1
        elseif name:find("azucar") or name:find("sugar") or name:find("bloke") or name:find("bloque") then s = s + 1
        elseif name:find("gelatina") or name:find("gelatin") then g = g + 1
        end
    end
    if LP.Character then
        for _, v in ipairs(LP.Character:GetChildren()) do
            if v:IsA("Tool") then check(v.Name) end
        end
    end
    for _, v in ipairs(LP.Backpack:GetChildren()) do
        if v:IsA("Tool") then check(v.Name) end
    end
    return w, s, g
end

local function getFarmedCounts()
    local sm, md, lg, unk = 0, 0, 0, 0
    local function check(name)
        name = name:lower()
        if name:find("vac") or name:find("empty") or name:find("sugar") or name:find("azucar")
           or name:find("bloque") or name:find("bloke") or name:find("water") or name:find("agua")
           or name:find("gelatin") then return end
        if name:find("small") or name:find("peque") then sm = sm + 1
        elseif name:find("medium") or name:find("median") then md = md + 1
        elseif name:find("large") or name:find("grand") then lg = lg + 1
        else unk = unk + 1 end
    end
    if LP.Character then
        for _, v in ipairs(LP.Character:GetChildren()) do
            if v:IsA("Tool") then check(v.Name) end
        end
    end
    for _, v in ipairs(LP.Backpack:GetChildren()) do
        if v:IsA("Tool") then check(v.Name) end
    end
    return sm, md, lg, unk
end

local function getClosestPrompt(keywords, exclude)
    local root = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local best, bestDist = nil, 1000
    for _, p in ipairs(workspace:GetDescendants()) do
        if p:IsA("ProximityPrompt") and p.Parent then
            local pn = p.Parent.Name:lower()
            local ppn = (p.Parent.Parent and p.Parent.Parent.Name or ""):lower()
            local at = p.ActionText:lower()
            local ot = p.ObjectText:lower()
            local excluded = false
            if exclude then
                for _, ex in ipairs(exclude) do
                    if pn:match(ex) or ppn:match(ex) or at:match(ex) or ot:match(ex) then
                        excluded = true; break
                    end
                end
            end
            if not excluded then
                local matched = #keywords == 0
                for _, kw in ipairs(keywords) do
                    if pn:match(kw) or ppn:match(kw) or at:match(kw) or ot:match(kw) then
                        matched = true; break
                    end
                end
                if matched then
                    local pos
                    if p.Parent:IsA("BasePart") then pos = p.Parent.Position
                    elseif p.Parent:IsA("Attachment") then pos = p.Parent.WorldPosition
                    elseif p.Parent:IsA("Model") and p.Parent.PrimaryPart then pos = p.Parent.PrimaryPart.Position
                    end
                    if pos then
                        local d = (pos - root.Position).Magnitude
                        if d < bestDist then bestDist = d; best = p end
                    end
                end
            end
        end
    end
    return best
end

local function equipTool(kw)
    local char = LP.Character
    if not char then return false end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(kw) then return true end
    end
    for _, v in ipairs(LP.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find(kw) then
            char.Humanoid:EquipTool(v); task.wait(0.15); return true
        end
    end
    return false
end

