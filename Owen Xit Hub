    if Typing then return end
    if input.UserInputType == CurrentTriggerKey or input.KeyCode == CurrentTriggerKey then
        if Env.Settings.Toggle then
            Running = not Running
        else
            Running = true
        end

        if Running then
            Env.Locked = GetClosestPlayer()
            if Env.Locked and NotifyLock and not StreamingMode then
                Rayfield:Notify({
                    Title    = "🎯 Locked",
                    Content  = "Apuntando a: " .. Env.Locked.Name,
                    Duration = 2
                })
            end
        else
            if CurrentTween then CurrentTween:Cancel() CurrentTween = nil end
            Env.Locked = nil
        end
    end
end)

