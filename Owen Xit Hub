local function startWallTool()
    if wallToolActive then return end
    wallToolActive = true
    local mouse = LP:GetMouse()
    selectionBox = Instance.new("SelectionBox")
    selectionBox.Color3 = Color3.fromRGB(255, 0, 100)
    selectionBox.SurfaceTransparency = 0.6
    selectionBox.Parent = workspace

    hoverConn = RunService.RenderStepped:Connect(function()
        if not wallToolActive then return end
        local t = mouse.Target
        if t and not t:IsDescendantOf(LP.Character) and t.Transparency < 1 then
            selectionBox.Adornee = t
        else
            selectionBox.Adornee = nil
        end
    end)

    mouseClickConn = mouse.Button1Down:Connect(function()
        local t = mouse.Target
        if t and not t:IsDescendantOf(LP.Character) and t.Transparency < 1 then
            table.insert(removedWalls, {
                Part = t, Transparency = t.Transparency,
                CanCollide = t.CanCollide, CFrame = t.CFrame
            })
            t.Transparency = 1
            t.CanCollide   = false
            t.CFrame       = t.CFrame + Vector3.new(0, 50000, 0)
            selectionBox.Adornee = nil
        end
    end)
end

