local R15Links = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
}
local R6Links = {
    {"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},
    {"Torso","Left Leg"},{"Torso","Right Leg"},
}

local function RemoveESP(p)
    local d = G.ESPObjects[p]
    if not d then return end
    for _, key in ipairs({"Box","Tracer","Name","HBBG","HB"}) do
        if d[key] then pcall(function() d[key]:Remove() end) end
    end
    for _, l in ipairs(d.SkelLines or {}) do pcall(function() l:Remove() end) end
    if d.Highlight then pcall(function() d.Highlight:Destroy() end) end
    G.ESPObjects[p] = nil
end

local function CreateESP(p)
    if G.ESPObjects[p] then return end
    local char = p.Character
    if not char then return end
    local links = char:FindFirstChild("UpperTorso") and R15Links or R6Links
    local d = { Links = links, SkelLines = {} }

    local function newDraw(class, props)
        local obj = Drawing.new(class)
        for k,v in pairs(props) do obj[k] = v end
        return obj
    end

    d.Box    = newDraw("Square",  {Filled=false,Transparency=1,Thickness=G.ESPThickness,Color=G.ESPColor,Visible=false})
    d.Tracer = newDraw("Line",    {Thickness=1.5,Transparency=1,Color=G.ESPColor,Visible=false})
    d.Name   = newDraw("Text",    {Center=true,Outline=true,OutlineColor=Color3.new(0,0,0),Font=2,Size=G.ESPTextSize,Transparency=1,Color=G.ESPColor,Visible=false})
    d.HBBG   = newDraw("Square",  {Filled=true,Color=Color3.new(0,0,0),Transparency=0.5,Visible=false})
    d.HB     = newDraw("Square",  {Filled=true,Transparency=1,Visible=false})

    for _ = 1, #links do
        table.insert(d.SkelLines, newDraw("Line",{Thickness=1.5,Transparency=0.8,Color=G.ESPColor,Visible=false}))
    end

    d.Highlight = Instance.new("Highlight")
    d.Highlight.FillTransparency    = G.ESPHighlightTrans
    d.Highlight.OutlineTransparency = 0
    d.Highlight.FillColor           = G.ESPColor
    d.Highlight.OutlineColor        = G.ESPColor
    d.Highlight.Adornee             = char
    d.Highlight.Parent              = Camera
    d.Highlight.Enabled             = false

    G.ESPObjects[p] = d
end

local function RefreshAllESP()
    for _, p in Players:GetPlayers() do
        if p ~= LP then RemoveESP(p) end
    end
    if G.ESPEnabled then
        for _, p in Players:GetPlayers() do
            if p ~= LP and p.Character then CreateESP(p) end
        end
    end
end

