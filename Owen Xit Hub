local function stopWallTool()
    wallToolActive = false
    if hoverConn      then hoverConn:Disconnect();      hoverConn      = nil end
    if mouseClickConn then mouseClickConn:Disconnect(); mouseClickConn = nil end
    if selectionBox   then selectionBox:Destroy();      selectionBox   = nil end
