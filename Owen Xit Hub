-- Hitbox Expander
local HitboxEnabled  = false
local HitboxSize     = 5
local HitboxPart     = "HumanoidRootPart"
local OriginalSizes  = {}

local function ApplyHitbox()
    for _, p in Players:GetPlayers() do
        if p == LP then
            continue
        end
        local c = p.Character
        if not c then
            continue
        end
        local part = c:FindFirstChild(HitboxPart)
        if not part then
            continue
        end
        if not OriginalSizes[p] then
            OriginalSizes[p] = part.Size
        end
        part.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
    end
end

local function RemoveHitbox()
    for p, originalSize in pairs(OriginalSizes) do
        local c = p.Character
        if not c then
            continue
        end
        local part = c:FindFirstChild(HitboxPart)
        if part then
            part.Size = originalSize
        end
    end
    OriginalSizes = {}
end

