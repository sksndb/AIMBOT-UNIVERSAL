    local function saveConfig()
        local data = {
            AimbotEnabled    = tostring(G.AimbotEnabled),
            LockPart         = G.LockPart,
            LockMode         = tostring(G.LockMode),
            Sensitivity      = tostring(G.Sensitivity),
