RunService.Heartbeat:Connect(function()
    if not G.AimRunning or not G.AimbotEnabled or not G.AimLocked then return end
    local char = G.AimLocked.Character
    local part = char and char:FindFirstChild(G.LockPart)
    if not part then
        if G.AimTween then G.AimTween:Cancel(); G.AimTween = nil end
        G.AimLocked = nil; G.AimRunning = false; return
    end
    local target = part.Position
    local scr    = Camera:WorldToViewportPoint(target)
    if G.LockMode == 2 then
        mousemoverel(
            (scr.X - UIS:GetMouseLocation().X) / G.Sensitivity2,
            (scr.Y - UIS:GetMouseLocation().Y) / G.Sensitivity2
        )
    else
        if G.Sensitivity > 0 then
            if G.AimTween then G.AimTween:Cancel() end
            G.AimTween = TweenService:Create(Camera,
                TweenInfo.new(G.Sensitivity, Enum.EasingStyle.Sine, Enum.EasingDirection.Out),
                {CFrame = CFrame.new(Camera.CFrame.Position, target)}
            )
            G.AimTween:Play()
        else
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, target)
        end
    end
end)

-- Triggerbot
RunService.Heartbeat:Connect(function()
    if not G.TriggerEnabled or not G.AimRunning or not G.AimLocked then return end
    local char = G.AimLocked.Character
    local part = char and char:FindFirstChild(G.LockPart)
    if not part then return end
    local myChar = LP.Character
    if not myChar then return end
    local ignore = {}
    for _,v in ipairs(myChar:GetDescendants()) do table.insert(ignore,v) end
    for _,v in ipairs(char:GetDescendants()) do table.insert(ignore,v) end
    if #Camera:GetPartsObscuringTarget({part.Position}, ignore) > 0 then return end
    local vec, onScr = Camera:WorldToViewportPoint(part.Position)
    if not onScr or vec.Z < 0 then return end
    VIM:SendMouseButtonEvent(0,0,0,true,game,1)
    task.wait(0.015)
    VIM:SendMouseButtonEvent(0,0,0,false,game,1)
end)

-- Aimbot input
local function inputMatches(input)
    if G.CurrentTriggerType then
        return input.UserInputType == G.CurrentTriggerType
    else
        return input.KeyCode == G.CurrentTriggerKey
    end
end

UIS.InputBegan:Connect(function(input, gpe)
    if gpe or G.AimTyping or not G.AimbotEnabled then return end
    if inputMatches(input) then
        if G.ToggleMode then
            G.AimRunning = not G.AimRunning
        else
            G.AimRunning = true
        end
        if G.AimRunning then
            G.AimLocked = GetClosestPlayer()
            if G.AimLocked and G.AimNotifyLock and G.RayfieldLib then
                pcall(function()
                    G.RayfieldLib:Notify({Title="Locked", Content="Apuntando a: "..G.AimLocked.Name, Duration=2})
                end)
            end
        else
            if G.AimTween then G.AimTween:Cancel(); G.AimTween = nil end
            G.AimLocked = nil
        end
    end
end)

UIS.InputEnded:Connect(function(input)
    if G.ToggleMode or G.AimTyping then return end
    if inputMatches(input) then
        G.AimRunning = false
        if G.AimTween then G.AimTween:Cancel(); G.AimTween = nil end
        G.AimLocked = nil
    end
end)

UIS.TextBoxFocused:Connect(function()       G.AimTyping = true  end)
UIS.TextBoxFocusReleased:Connect(function() G.AimTyping = false end)

