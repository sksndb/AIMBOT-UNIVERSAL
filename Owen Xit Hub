            ESPTextSize      = tostring(G.ESPTextSize),
            ESPMaxDistance   = tostring(G.ESPMaxDistance),
            ESPHighlightTrans= tostring(G.ESPHighlightTrans),
        }
        local lines = {}
        for k, v in pairs(data) do
            table.insert(lines, k .. "=" .. v)
        end
        pcall(function() writefile(CONFIG_FILE, table.concat(lines, "\n")) end)
    end

    local function loadConfig()
        local ok, content = pcall(function() return readfile(CONFIG_FILE) end)
        if not ok or not content then return false end
        local parsed = {}
        for line in content:gmatch("[^\n]+") do
            local k, v = line:match("^(.-)=(.+)$")
            if k and v then parsed[k] = v end
        end
        local function toBool(s) return s == "true" end
        local function toNum(s)  return tonumber(s) or 0 end
        if parsed.AimbotEnabled   then G.AimbotEnabled   = toBool(parsed.AimbotEnabled)   end
