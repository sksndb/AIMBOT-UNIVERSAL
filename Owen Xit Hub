-- Crosshair
local CrosshairEnabled = false
local CrosshairColor   = Color3.fromRGB(255, 255, 255)
local CrosshairSize    = 10
local CrosshairThick   = 1
local CrosshairLines   = {}

local function CreateCrosshair()
    for _, l in ipairs(CrosshairLines) do
        l:Remove()
    end
    CrosshairLines = {}
    for _ = 1, 4 do
        local l = Drawing.new("Line")
        l.Thickness = CrosshairThick
        l.Color     = CrosshairColor
        l.Transparency = 1
        l.Visible   = false
        table.insert(CrosshairLines, l)
    end
end
CreateCrosshair()

local function UpdateCrosshair()
    if not CrosshairEnabled or StreamingMode then
        for _, l in ipairs(CrosshairLines) do
            l.Visible = false
        end
        return
    end
    local cx = Camera.ViewportSize.X / 2
    local cy = Camera.ViewportSize.Y / 2
    local s  = CrosshairSize
    local positions = {
        {Vector2.new(cx - s, cy), Vector2.new(cx - 3, cy)},
        {Vector2.new(cx + 3, cy), Vector2.new(cx + s, cy)},
        {Vector2.new(cx, cy - s), Vector2.new(cx, cy - 3)},
        {Vector2.new(cx, cy + 3), Vector2.new(cx, cy + s)},
    }
    for i, l in ipairs(CrosshairLines) do
        l.From    = positions[i][1]
        l.To      = positions[i][2]
        l.Color   = CrosshairColor
        l.Thickness = CrosshairThick
        l.Visible = true
    end
end

